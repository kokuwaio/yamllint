{
	"$schema": "https://docs.renovatebot.com/renovate-schema.json",
	"extends": ["kokuwaio/renovate-config"],
	"packageRules": [
		{
			"matchPackageNames": "adrienverge/yamllint",
			"automerge": true
		}
	],
	"customManagers": [
		{
			"customType": "regex",
			"managerFilePatterns": ["README.md", "Dockerfile", ".woodpecker/build.yaml"],
			"matchStrings": [
				"kokuwaio/yamllint:(?<currentValue>v\\d+\\.\\d+\\.\\d+)",
				"yamllint==(?<currentValue>v\\d+\\.\\d+\\.\\d+)",
				"version: (?<currentValue>v\\d+\\.\\d+\\.\\d+)"
			],
			"datasourceTemplate": "github-releases",
			"packageNameTemplate": "adrienverge/yamllint"
		}
	]
}
